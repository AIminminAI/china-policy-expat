{
  "rewrites": [
    { "source": "/api/policies", "destination": "/api/policies" },
    { "source": "/api/calculate", "destination": "/api/calculate" },
    { "source": "/api/checkout", "destination": "/api/checkout" },
    { "source": "/api/subscribe", "destination": "/api/subscribe" },
    { "source": "/api/webhook/creem", "destination": "/api/webhook/creem" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,x-api-key" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
